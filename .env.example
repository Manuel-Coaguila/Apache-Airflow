# Airflow UID
AIRFLOW_UID=1000
AIRFLOW_GID=0

# Fernet Key (generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FERNET_KEY=

# JWT
AIRFLOW__API_AUTH__JWT_SECRET=
AIRFLOW__API_AUTH__JWT_ISSUER=airflow

# Usuario Airflow
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=admin

# Infraestructura — Postgres (BD interna de Airflow)
POSTGRES_HOST=postgres
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# Infraestructura — Redis (broker Celery)
REDIS_HOST=redis
REDIS_PASSWORD=changeme

# Shared — SQL Server (host y puerto compartidos)
SQL_SERVER_HOST=sql_server_2019
SQL_SERVER_PORT=1433

# Proyecto 001 — SQL Server credentials + ETL paths
P001_SQL_SERVER_DATABASE=master
P001_SQL_SERVER_USER=sa
P001_SQL_SERVER_PASSWORD=
P001_PROJECT_HOME=/opt/spark/projects/proyecto_001
P001_LOGGING_CONF=${P001_PROJECT_HOME}/conf/logging.yaml

# Proyecto 002 — template
# P002_SQL_SERVER_DATABASE=
# P002_SQL_SERVER_USER=
# P002_SQL_SERVER_PASSWORD=
# P002_PROJECT_HOME=/opt/spark/projects/proyecto_002
